# ═══════════════════════════════════════════════
# FACTUEL — Variables d'environnement
# Copier ce fichier en ".env" et remplir les clés
# Ne JAMAIS commiter le fichier .env
# ═══════════════════════════════════════════════

# ── IA RÉDACTRICE (obligatoire) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SOURCES D'INFORMATIONS ──────────────────────

# NewsAPI — 100 req/jour gratuit
# Inscription : https://newsapi.org/register
NEWSAPI_KEY=

# The Guardian — gratuit illimité
# Inscription : https://open-platform.theguardian.com/access/
GUARDIAN_KEY=

# Brave Search — 2 000 req/mois gratuit
# Inscription : https://api.search.brave.com/
BRAVE_SEARCH_KEY=

# ── DÉPLOIEMENT (optionnel) ──────────────────────

# Netlify — pour déploiement automatique via CLI
# npm install -g netlify-cli && netlify login
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
